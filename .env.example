# ============================================================
# Café & Co. | Demo — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ============================================================

# Public site URL — used for canonical URLs, sitemap, Open Graph, JSON-LD
NEXT_PUBLIC_SITE_URL=https://www.farmgatecafe.com.au

# Cloudflare Turnstile (optional bot protection for the contact form)
# Leave blank to disable Turnstile and rely on the honeypot field only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# Outbound email (contact form confirmations + owner notifications)
# Works with a Gmail account + App Password, or swap the transport in lib/email.ts
# for any SMTP provider (Postmark, Resend, SES, etc.) at deploy time.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Address the "new enquiry" notification email is sent to (defaults to GMAIL_USER)
OWNER_NOTIFICATION_EMAIL=hello@farmgatecafe.com.au
